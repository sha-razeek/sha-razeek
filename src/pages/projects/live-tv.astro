---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Live TV Player" description="Watch live TV channels from around the world">
  <nav class="breadcrumb">
    <a href="/projects">Projects</a>
    <span class="breadcrumb-sep">→</span>
    <span class="breadcrumb-current">Live TV</span>
  </nav>

  <div class="page-header">
    <h1>📺 Live TV</h1>
    <p class="subtitle">Watch live television channels from around the world</p>
  </div>

  <div class="tv-app">
    <!-- Player -->
    <div class="player-wrapper" id="playerWrapper" style="display: none;">
      <div class="player-now-playing">
        <div class="np-logo" id="npLogo"></div>
        <div class="np-info">
          <span class="np-name" id="npName">—</span>
          <span class="np-meta" id="npMeta">—</span>
        </div>
        <button class="player-close-btn" id="btnClose" title="Close player">✕</button>
      </div>
      <video id="videoPlayer" controls autoplay muted></video>
    </div>

    <!-- Search -->
    <div class="tv-search">
      <input type="text" id="searchInput" placeholder="Search channels by name or country..." class="search-input" />
      <button class="btn btn--primary" id="btnSearch">Search</button>
    </div>

    <!-- Filter tabs -->
    <div class="tv-tabs">
      <button class="tab active" data-tab="all">All</button>
      <button class="tab" data-tab="news">News</button>
      <button class="tab" data-tab="entertainment">Entertainment</button>
      <button class="tab" data-tab="sports">Sports</button>
      <button class="tab" data-tab="kids">Kids</button>
      <button class="tab" data-tab="music">Music</button>
    </div>

    <!-- Channel grid -->
    <div class="channel-grid" id="channelGrid">
      <div class="loading-state">
        <div class="loading-spinner"></div>
        <p>Loading channels...</p>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    margin-bottom: 1.5rem;
    color: var(--color-warm-gray);
  }
  .breadcrumb a { color: var(--accent-primary); }
  .breadcrumb-sep { opacity: 0.5; }

  .tv-app { max-width: 900px; }

  /* Player */
  .player-wrapper {
    margin-bottom: 1.5rem;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #000;
    box-shadow: var(--shadow-lg);
  }

  .player-now-playing {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-dark);
    color: white;
  }

  .np-logo {
    width: 36px;
    height: 36px;
    border-radius: 6px;
    overflow: hidden;
    background: rgba(255,255,255,0.1);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .np-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .np-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .np-name {
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .np-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .player-close-btn {
    width: 32px;
    height: 32px;
    border: none;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    color: white;
    cursor: pointer;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition-fast);
  }

  .player-close-btn:hover {
    background: rgba(255,255,255,0.2);
  }

  #videoPlayer {
    width: 100%;
    aspect-ratio: 16 / 9;
    display: block;
    background: #111;
  }

  /* Search */
  .tv-search {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .search-input {
    flex: 1;
    padding: 0.65rem 1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    border: 1.5px solid var(--border-color);
    border-radius: var(--radius-md);
    background: white;
    color: var(--text-primary);
    transition: border-color var(--transition-fast);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--accent-primary);
  }

  /* Tabs */
  .tv-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    flex-wrap: wrap;
  }

  .tab {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.55rem 0.85rem;
    border: none;
    background: none;
    color: var(--color-warm-gray);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: all var(--transition-fast);
  }

  .tab:hover { color: var(--text-primary); }
  .tab.active {
    color: var(--accent-primary);
    border-bottom-color: var(--accent-primary);
  }

  /* Channel grid */
  .channel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .channel-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    padding: 1.1rem 0.85rem;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    cursor: pointer;
    transition: all var(--transition-fast);
    text-align: center;
  }

  .channel-card:hover {
    border-color: var(--accent-primary);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .channel-card.active {
    border-color: var(--accent-primary);
    background: rgba(42, 157, 143, 0.06);
  }

  .channel-logo {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .channel-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .channel-logo-placeholder {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    background: rgba(42, 157, 143, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--accent-primary);
  }

  .channel-name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.9rem;
    line-height: 1.3;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .channel-country {
    font-size: 0.75rem;
    color: var(--text-secondary);
  }

  .channel-quality {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.15em 0.5em;
    border-radius: 100px;
    background: rgba(42, 157, 143, 0.08);
    color: var(--accent-primary);
  }

  .loading-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-warm-gray);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  .loading-spinner {
    width: 28px;
    height: 28px;
    border: 2.5px solid var(--border-color);
    border-top-color: var(--accent-primary);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 1rem;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 3rem 1rem;
    color: var(--color-warm-gray);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .channel-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); }
    .tv-tabs { gap: 0; }
  }
</style>

<script>
  const CHANNELS_API = 'https://iptv-org.github.io/api/channels.json';
  const STREAMS_API = 'https://iptv-org.github.io/api/streams.json';
  const LOGOS_API = 'https://iptv-org.github.io/api/logos.json';
  const COUNTRIES_API = 'https://iptv-org.github.io/api/countries.json';

  interface Channel {
    id: string;
    name: string;
    country: string;
    categories: string[];
  }

  interface Stream {
    channel: string | null;
    title: string;
    url: string;
    quality: string | null;
    label: string | null;
  }

  interface Logo {
    channel: string;
    url: string;
  }

  interface Country {
    code: string;
    name: string;
    flag: string;
  }

  interface TVChannel {
    channel: Channel;
    stream: Stream;
    logo: string | null;
    countryName: string;
    countryFlag: string;
  }

  let allChannels: TVChannel[] = [];
  let filteredChannels: TVChannel[] = [];
  let currentChannel: TVChannel | null = null;
  let activeCategory = 'all';

  const channelGrid = document.getElementById('channelGrid')!;
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const btnSearch = document.getElementById('btnSearch')!;
  const playerWrapper = document.getElementById('playerWrapper')!;
  const videoPlayer = document.getElementById('videoPlayer') as HTMLVideoElement;
  const npLogo = document.getElementById('npLogo')!;
  const npName = document.getElementById('npName')!;
  const npMeta = document.getElementById('npMeta')!;
  const btnClose = document.getElementById('btnClose')!;

  async function init() {
    try {
      const [channelsRes, streamsRes, logosRes, countriesRes] = await Promise.all([
        fetch(CHANNELS_API).then(r => r.json()),
        fetch(STREAMS_API).then(r => r.json()),
        fetch(LOGOS_API).then(r => r.json()),
        fetch(COUNTRIES_API).then(r => r.json()),
      ]);

      const channels: Channel[] = channelsRes;
      const streams: Stream[] = streamsRes;
      const logos: Logo[] = logosRes;
      const countries: Country[] = countriesRes;

      // Build lookup maps
      const channelMap = new Map<string, Channel>();
      channels.forEach(c => channelMap.set(c.id, c));

      const logoMap = new Map<string, string>();
      logos.forEach(l => {
        if (!logoMap.has(l.channel)) logoMap.set(l.channel, l.url);
      });

      const countryMap = new Map<string, Country>();
      countries.forEach(c => countryMap.set(c.code, c));

      // Merge streams with channels
      allChannels = streams
        .filter(s => s.channel && channelMap.has(s.channel) && !s.label)
        .map(s => {
          const ch = channelMap.get(s.channel!)!;
          const co = countryMap.get(ch.country);
          return {
            channel: ch,
            stream: s,
            logo: logoMap.get(ch.id) || null,
            countryName: co?.name || ch.country,
            countryFlag: co?.flag || '',
          };
        });

      filteredChannels = allChannels;
      renderChannels(filteredChannels);
      setupTabs();
    } catch (err) {
      channelGrid.innerHTML = '<div class="empty-state">Could not load channels. Please try again later.</div>';
    }
  }

  function setupTabs() {
    document.querySelectorAll('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        activeCategory = tab.getAttribute('data-tab')!;
        applyFilters();
      });
    });
  }

  function applyFilters() {
    const query = searchInput.value.trim().toLowerCase();
    filteredChannels = allChannels.filter(ch => {
      const matchesCategory = activeCategory === 'all' || ch.channel.categories.includes(activeCategory);
      const matchesSearch = !query ||
        ch.channel.name.toLowerCase().includes(query) ||
        ch.countryName.toLowerCase().includes(query) ||
        ch.stream.title.toLowerCase().includes(query);
      return matchesCategory && matchesSearch;
    });
    renderChannels(filteredChannels);
  }

  function renderChannels(channels: TVChannel[]) {
    if (channels.length === 0) {
      channelGrid.innerHTML = '<div class="empty-state">No channels found.</div>';
      return;
    }

    // Show first 100 to avoid rendering too many
    const display = channels.slice(0, 100);

    channelGrid.innerHTML = display.map(ch => `
      <div class="channel-card ${currentChannel?.channel.id === ch.channel.id ? 'active' : ''}" data-id="${ch.channel.id}">
        ${ch.logo
          ? `<div class="channel-logo"><img src="${ch.logo}" alt="" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"><div class="channel-logo-placeholder" style="display:none">📺</div></div>`
          : `<div class="channel-logo-placeholder">📺</div>`
        }
        <div class="channel-name">${escapeHtml(ch.channel.name)}</div>
        <div class="channel-country">${ch.countryFlag} ${escapeHtml(ch.countryName)}</div>
        ${ch.stream.quality ? `<span class="channel-quality">${ch.stream.quality}</span>` : ''}
      </div>
    `).join('');

    if (channels.length > 100) {
      channelGrid.innerHTML += `<div class="empty-state">Showing 100 of ${channels.length} channels. Refine your search to see more.</div>`;
    }

    // Bind click events
    channelGrid.querySelectorAll('.channel-card').forEach(card => {
      card.addEventListener('click', () => {
        const id = card.getAttribute('data-id')!;
        const ch = display.find(c => c.channel.id === id);
        if (ch) playChannel(ch);
      });
    });
  }

  function playChannel(ch: TVChannel) {
    currentChannel = ch;
    const url = ch.stream.url;
    const isHls = url.includes('.m3u8');

    if (isHls && typeof (window as any).Hls !== 'undefined' && (window as any).Hls.isSupported()) {
      const hls = new (window as any).Hls();
      hls.loadSource(url);
      hls.attachMedia(videoPlayer);
      hls.on((window as any).Hls.Events.MANIFEST_PARSED, () => videoPlayer.play());
    } else if (isHls) {
      videoPlayer.src = url;
      videoPlayer.play();
    } else {
      videoPlayer.src = url;
      videoPlayer.play();
    }

    playerWrapper.style.display = 'block';

    if (ch.logo) {
      npLogo.innerHTML = `<img src="${ch.logo}" alt="">`;
    } else {
      npLogo.innerHTML = '📺';
    }

    npName.textContent = ch.channel.name;
    npMeta.textContent = `${ch.countryFlag} ${ch.countryName} · ${ch.stream.quality || 'N/A'}`;

    // Highlight active card
    channelGrid.querySelectorAll('.channel-card').forEach(c => c.classList.remove('active'));
    const activeCard = channelGrid.querySelector(`[data-id="${ch.channel.id}"]`);
    activeCard?.classList.add('active');

    // Scroll player into view
    playerWrapper.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function stopPlayback() {
    videoPlayer.pause();
    videoPlayer.src = '';
    playerWrapper.style.display = 'none';
    currentChannel = null;
    channelGrid.querySelectorAll('.channel-card').forEach(c => c.classList.remove('active'));
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Event listeners
  btnSearch.addEventListener('click', applyFilters);
  searchInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') applyFilters();
  });
  searchInput.addEventListener('input', () => {
    applyFilters();
  });
  btnClose.addEventListener('click', stopPlayback);

  // Load HLS.js from CDN for .m3u8 streams
  if (!document.querySelector('script[src*="hls"]')) {
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/hls.js@latest';
    document.head.appendChild(script);
  }

  init();
</script>
