---
import Layout from '../layouts/Layout.astro';
import { musicArticles } from '../data/music';
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-atomic">✦</div>
    <p class="hero-greeting">Welcome to the orbital</p>
    <h1 class="hero-name">Sha Razeek</h1>
    <p class="hero-role">Developer · Hypermedia Specialist · UI/UX Designer</p>
    <div class="hero-divider">
      <span class="divider-star">◈</span>
    </div>
    <p class="hero-desc">
      Crafting digital experiences at the crossroads of design and technology.
      Currently serving as Associate Director at Acuity Analytics.
    </p>
    <div class="hero-actions">
      <a href="/portfolio" class="btn btn--primary">View Portfolio</a>
      <a href="/about" class="btn">About Me</a>
    </div>
  </section>

  <!-- Recent Articles Preview -->
  <section class="section">
    <div class="section-header">
      <h2>Recently Written</h2>
      <a href="/blog" class="section-link">All Articles →</a>
    </div>
    <div class="articles-grid stagger">
      <a href="/blog/city-pop" class="card article-card">
        <div class="article-card-image" style="background: linear-gradient(135deg, #E76F51, #E9C46A)">
          <span class="article-card-icon">♪</span>
        </div>
        <div class="article-card-body">
          <span class="tag tag--coral">City Pop</span>
          <h3>Tokyo's Neon Dreamscape</h3>
          <p>The glossy, sun-drenched sound of 1980s Japanese City Pop and how it became a global phenomenon.</p>
          <span class="article-date">May 2026</span>
        </div>
      </a>
      <a href="/blog/enka" class="card article-card">
        <div class="article-card-image" style="background: linear-gradient(135deg, #264653, #2A9D8F)">
          <span class="article-card-icon">♫</span>
        </div>
        <div class="article-card-body">
          <span class="tag">Enka</span>
          <h3>The Soul of Japan</h3>
          <p>A deep dive into Japan's ballad tradition that blends Western melodies with Japanese pentatonic scales.</p>
          <span class="article-date">May 2026</span>
        </div>
      </a>
      <a href="/blog/dangdut" class="card article-card">
        <div class="article-card-image" style="background: linear-gradient(135deg, #F4A261, #E76F51)">
          <span class="article-card-icon">♪</span>
        </div>
        <div class="article-card-body">
          <span class="tag tag--mustard">Dangdut</span>
          <h3>The People's Music of Indonesia</h3>
          <p>From the streets of Jakarta to global diaspora — the rhythmic, rebellious sound of Dangdut.</p>
          <span class="article-date">May 2026</span>
        </div>
      </a>
      <a href="/blog/ruby-llm" class="card article-card">
        <div class="article-card-image" style="background: linear-gradient(135deg, #CC342D, #E76F51)">
          <span class="article-card-icon">◇</span>
        </div>
        <div class="article-card-body">
          <span class="tag tag--coral">Technology</span>
          <h3>Ruby and the Art of Talking to Machines</h3>
          <p>Why Ruby's elegant syntax makes it surprisingly beautiful for working with LLMs.</p>
          <span class="article-date">May 2026</span>
        </div>
      </a>
    </div>
  </section>

  <!-- Applications Section -->
  <section class="section">
    <div class="section-header">
      <h2>Applications</h2>
    </div>
    <div class="apps-container stagger">
      <a href="/music/transistor" class="app-promo-card app-promo-card--transistor">
        <div class="app-promo-content">
          <div class="app-promo-header">
            <span class="app-promo-icon">📻</span>
            <div class="app-promo-title-group">
              <h3 class="app-promo-title">Transistor</h3>
              <span class="app-promo-tag">Radio Receiver</span>
            </div>
          </div>
          <p class="app-promo-desc">Global radio broadcasting at your fingertips. Tuned to thousands of stations worldwide with a retro-futuristic interface.</p>
          <div class="app-promo-footer">
            <span class="btn btn--small">Launch Station →</span>
          </div>
        </div>
        <div class="app-promo-visual">
          <div class="visual-circle"></div>
          <div class="visual-waves">
            <span></span><span></span><span></span>
          </div>
        </div>
      </a>

      <a href="/projects/cathode" class="app-promo-card app-promo-card--cathode">
        <div class="app-promo-content">
          <div class="app-promo-header">
            <span class="app-promo-icon">📺</span>
            <div class="app-promo-title-group">
              <h3 class="app-promo-title">Cathode</h3>
              <span class="app-promo-tag">Vision Monitor</span>
            </div>
          </div>
          <p class="app-promo-desc">Direct satellite transmission from across the globe. Seamless streaming of live international television channels.</p>
          <div class="app-promo-footer">
            <span class="btn btn--small">Direct Feed →</span>
          </div>
        </div>
        <div class="app-promo-visual">
          <div class="visual-test-pattern"></div>
        </div>
      </a>
    </div>
  </section>

  <!-- Quick Links -->
  <section class="section">
    <div class="section-header">
      <h2>Explore</h2>
    </div>
    <div class="explore-grid stagger">
      <a href="/music" class="explore-card">
        <span class="explore-icon">♪</span>
        <span class="explore-label">Music</span>
        <span class="explore-desc">Playlists & writing</span>
      </a>
      <a href="/trivia" class="explore-card">
        <span class="explore-icon">⬡</span>
        <span class="explore-label">Trivia</span>
        <span class="explore-desc">Weekly quizzes</span>
      </a>
      <a href="/portfolio" class="explore-card">
        <span class="explore-icon">◎</span>
        <span class="explore-label">Portfolio</span>
        <span class="explore-desc">Selected works</span>
      </a>
      <a href="/about" class="explore-card">
        <span class="explore-icon">◇</span>
        <span class="explore-label">About</span>
        <span class="explore-desc">Who I am</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
    position: relative;
  }

  .hero-atomic {
    font-size: 1.5rem;
    color: var(--accent-secondary);
    animation: atomicSpin 10s linear infinite;
    margin-bottom: 1.5rem;
    display: inline-block;
  }

  .hero-greeting {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-warm-gray);
    margin-bottom: 0.75rem;
  }

  .hero-name {
    font-size: 3.75rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--color-dark), var(--accent-primary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-role {
    font-size: 1.2rem;
    color: var(--text-secondary);
    font-weight: 300;
    margin-bottom: 1.5rem;
  }

  .hero-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .hero-divider::before,
  .hero-divider::after {
    content: '';
    width: 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-warm-gray), transparent);
  }

  .divider-star {
    color: var(--accent-primary);
    font-size: 0.75rem;
  }

  .hero-desc {
    max-width: 500px;
    margin: 0 auto 2rem;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Sections */
  .section {
    margin-top: 3rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.25rem;
  }

  .section-header h2 {
    font-size: 1.625rem;
    margin-bottom: 0;
  }

  .section-link {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Article Cards */
  .article-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    padding: 0;
    overflow: hidden;
  }

  .article-card:hover {
    color: inherit;
  }

  .article-card-image {
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .article-card-icon {
    font-size: 2rem;
    color: white;
    opacity: 0.9;
  }

  .article-card-body {
    padding: 1.25rem;
  }

  .article-card-body h3 {
    font-size: 1.175rem;
    margin: 0.5rem 0;
  }

  .article-card-body p {
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
  }

  .article-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Explore Grid */
  .explore-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  /* App Promo Cards */
  .apps-container {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .app-promo-card {
    display: grid;
    grid-template-columns: 1fr 240px;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    transition: all var(--transition-medium);
    min-height: 200px;
  }

  .app-promo-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--accent-primary);
  }

  .app-promo-content {
    padding: 2.25rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .app-promo-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .app-promo-icon {
    font-size: 2.5rem;
  }

  .app-promo-title {
    font-size: 1.75rem;
    margin: 0;
    line-height: 1;
  }

  .app-promo-tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-warm-gray);
  }

  .app-promo-desc {
    font-size: 1.05rem;
    color: var(--text-secondary);
    max-width: 480px;
    margin-bottom: 1.5rem;
  }

  .app-promo-visual {
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    border-left: 1px solid var(--border-color);
  }

  .app-promo-card--transistor .app-promo-visual {
    background: linear-gradient(135deg, var(--color-dark), var(--accent-primary));
  }

  .app-promo-card--cathode .app-promo-visual {
    background: linear-gradient(135deg, #264653, #3D405B);
  }

  /* Visual Elements */
  .visual-circle {
    width: 120px;
    height: 120px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    position: absolute;
  }

  .visual-waves span {
    display: block;
    width: 160px;
    height: 1px;
    background: rgba(255,255,255,0.15);
    margin: 10px 0;
    transform: skewY(-15deg);
  }

  .visual-test-pattern {
    width: 140px;
    height: 140px;
    background: repeating-conic-gradient(
      from 0deg,
      rgba(255,255,255,0.05) 0deg 90deg,
      transparent 90deg 180deg
    );
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 50%;
    animation: atomicSpin 20s linear infinite;
  }

  .explore-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.5rem 1rem;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--text-primary);
    transition: all var(--transition-medium);
    text-align: center;
  }

  .explore-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--accent-primary);
    color: var(--text-primary);
  }

  .explore-icon {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .explore-label {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
  }

  .explore-desc {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 640px) {
    .hero-name { font-size: 2.75rem; }
    .articles-grid { grid-template-columns: 1fr; }
    .explore-grid { grid-template-columns: repeat(2, 1fr); }
    .app-promo-card { grid-template-columns: 1fr; }
    .app-promo-visual { display: none; }
  }
</style>
