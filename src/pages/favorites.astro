---
import Layout from '../layouts/Layout.astro';
import { favorites } from '../data/favorites';

const sections = [
  { id: 'book', label: 'Books', icon: '📖' },
  { id: 'movie', label: 'Movies', icon: '🎬' },
  { id: 'tv', label: 'TV Shows', icon: '📺' },
  { id: 'music', label: 'Music', icon: '♪' },
];

const getItemsByType = (type: string) => favorites.filter(item => item.type === type);
---

<Layout title="Favorites" description="Recommended books, movies, TV shows, and music albums by Sha Razeek">
  <div class="page-header">
    <h1>Favorites</h1>
    <p class="subtitle">A curated collection of things that move, inspire, and entertain me</p>
  </div>

  <div class="favorites-content">
    {sections.map(section => {
      const items = getItemsByType(section.id);
      if (items.length === 0) return null;
      
      return (
        <section class="fav-section">
          <div class="section-header">
            <h2 class="fav-section-title">
              <span class="fav-section-icon">{section.icon}</span>
              {section.label}
            </h2>
          </div>
          
          <div class="favorites-grid">
            {items.map((item) => (
              <div class="card favorite-card" data-type={item.type}>
                <div class="favorite-image-container">
                  <img 
                    src={item.coverImage || `https://placehold.co/${item.type === 'music' ? '400x400' : '400x600'}/f4f1ea/264653?text=${encodeURIComponent(item.title)}`} 
                    alt={item.title} 
                    class="favorite-img"
                  />
                </div>
                
                <div class="favorite-card-body">
                  <div class="favorite-header">
                    <h3>{item.title}</h3>
                    {item.year && <span class="favorite-year">{item.year}</span>}
                  </div>
                  
                  <p class="favorite-creator">{item.creator}</p>
                  
                  {item.description && <p class="favorite-desc">{item.description}</p>}
                </div>
              </div>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</Layout>

<style>
  .favorites-content {
    max-width: 960px;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .fav-section {
    display: flex;
    flex-direction: column;
  }

  .fav-section-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.8rem;
    margin-bottom: 2rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.75rem;
  }

  .fav-section-icon {
    font-size: 1.5rem;
  }

  /* Grid and Cards */
  .favorites-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .favorite-card {
    display: flex;
    flex-direction: column;
    padding: 0;
    height: 100%;
    position: relative;
    border-top: 4px solid var(--border-color);
    transition: all var(--transition-medium);
    overflow: hidden;
  }

  .favorite-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-top-color: var(--accent-primary);
  }

  .favorite-image-container {
    width: 100%;
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Aspect ratios: 1:1 for music, 2:3 for others */
  .favorite-card[data-type="music"] .favorite-image-container {
    aspect-ratio: 1 / 1;
  }
  
  .favorite-card:not([data-type="music"]) .favorite-image-container {
    aspect-ratio: 2 / 3;
  }

  .favorite-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-medium);
  }

  .favorite-card:hover .favorite-img {
    transform: scale(1.05);
  }

  .favorite-card-body {
    padding: 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .favorite-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 0.25rem;
  }

  .favorite-card h3 {
    font-size: 1.25rem;
    margin-bottom: 0;
    color: var(--text-primary);
  }

  .favorite-year {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-warm-gray);
    white-space: nowrap;
  }

  .favorite-creator {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--accent-primary);
    margin-bottom: 1rem;
  }

  .favorite-desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-secondary);
    margin-bottom: 0;
  }

  /* Specific border colors for types */
  .favorite-card[data-type="book"] { border-top-color: var(--accent-warm); }
  .favorite-card[data-type="movie"] { border-top-color: var(--accent-secondary); }
  .favorite-card[data-type="tv"] { border-top-color: var(--color-charcoal); }
  .favorite-card[data-type="music"] { border-top-color: var(--accent-primary); }

  @media (max-width: 768px) {
    .favorites-grid {
      grid-template-columns: 1fr;
    }
    
    .favorites-content {
      gap: 3rem;
    }

    .fav-section-title {
      font-size: 1.5rem;
    }
  }
</style>
