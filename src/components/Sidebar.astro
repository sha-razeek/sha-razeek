---
<!-- Mobile overlay -->
<div id="sidebar-overlay" class="sidebar-overlay"></div>

<!-- Mobile toggle button -->
<button id="sidebar-toggle" class="sidebar-toggle" aria-label="Toggle menu">
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
  <span class="hamburger-line"></span>
</button>

<aside id="sidebar" class="sidebar">
  <div class="sidebar-inner">
    <!-- Logo / Identity -->
    <a href="/" class="sidebar-brand">
      <div class="brand-icon">
        <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <!-- Starburst / Atomic motif -->
          <circle cx="16" cy="16" r="2.5" fill="currentColor"/>
          <circle cx="16" cy="16" r="7" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2.5"/>
          <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="0.75" stroke-dasharray="1.5 3"/>
          <path d="M16 1 L16.8 5 L15.2 5 Z" fill="currentColor" opacity="0.7"/>
          <path d="M16 31 L16.8 27 L15.2 27 Z" fill="currentColor" opacity="0.7"/>
          <path d="M1 16 L5 15.2 L5 16.8 Z" fill="currentColor" opacity="0.7"/>
          <path d="M31 16 L27 15.2 L27 16.8 Z" fill="currentColor" opacity="0.7"/>
          <path d="M5.4 5.4 L8.3 7.3 L7.3 8.3 Z" fill="currentColor" opacity="0.5"/>
          <path d="M26.6 26.6 L23.7 24.7 L24.7 23.7 Z" fill="currentColor" opacity="0.5"/>
          <path d="M26.6 5.4 L24.7 8.3 L23.7 7.3 Z" fill="currentColor" opacity="0.5"/>
          <path d="M5.4 26.6 L7.3 23.7 L8.3 24.7 Z" fill="currentColor" opacity="0.5"/>
        </svg>
      </div>
      <div class="brand-text">
        <span class="brand-name">Sha Razeek</span>
        <span class="brand-title">Developer & Designer</span>
      </div>
    </a>

    <!-- Navigation -->
    <nav class="sidebar-nav">
      {navItems.map(item => {
        const isCurrentParent = normalizedPath === item.href;
        const hasActiveChild = item.children && item.children.some(c => c.href === normalizedPath);
        const isActive = isCurrentParent || hasActiveChild;
        
        // For 'About', we only show children if we are in the About section (Parent or Child active)
        // For others, we keep them always visible for better UX
        const showChildren = item.children && (item.href === '/about' ? isActive : true);

        return (
          <div class="nav-group">
            <a href={item.href} class={`nav-link ${isActive ? 'active' : ''} ${item.featured ? 'nav-link--featured' : ''}`}>
              <span class="nav-icon" set:html={item.icon}></span>
              <span class="nav-label">{item.label}</span>
              <span class="nav-arrow">→</span>
            </a>            {showChildren && (
                <div class="nav-sub">
                  {item.children.map(child => {
                    const isChildActive = normalizedPath === child.href;
                    return (
                      <a href={child.href} class={`nav-link nav-link--sub ${isChildActive ? 'active' : ''}`}>
                        <span class="nav-icon nav-icon--sub" set:html={child.icon}></span>
                        <span class="nav-label">{child.label}</span>
                      </a>
                    );
                  })}
                </div>
              )}          </div>
        );
      })}
    </nav>

    <!-- Footer info -->
    <div class="sidebar-footer">
      <div class="jet-line-sidebar"></div>
      <p class="sidebar-tagline">Hypermedia & UI/UX</p>
      <p class="sidebar-location">✦ Available for work</p>
    </div>
  </div>
</aside>

<style>
  /* ---- Sidebar Overlay (mobile) ---- */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(38, 70, 83, 0.3);
    backdrop-filter: blur(2px);
    z-index: 90;
    opacity: 0;
    transition: opacity var(--transition-medium);
  }

  .sidebar-overlay.active {
    display: block;
    opacity: 1;
  }

  /* ---- Mobile Toggle ---- */
  .sidebar-toggle {
    display: none;
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 100;
    width: 40px;
    height: 40px;
    background: white;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    cursor: pointer;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-fast);
  }

  .sidebar-toggle:hover {
    box-shadow: var(--shadow-md);
  }

  .hamburger-line {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--text-primary);
    transition: all var(--transition-fast);
  }

  /* ---- Sidebar ---- */
  .sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 260px;
    height: 100vh;
    background: white;
    border-right: 1px solid var(--border-color);
    z-index: 95;
    overflow-y: auto;
    transition: transform var(--transition-medium);
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 2rem 0;
  }

  /* ---- Brand ---- */
  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0 1.5rem;
    margin-bottom: 2.5rem;
    text-decoration: none;
    color: var(--text-primary);
    transition: opacity var(--transition-fast);
  }

  .sidebar-brand:hover {
    opacity: 0.8;
    color: var(--text-primary);
  }

  .brand-icon {
    color: var(--accent-primary);
    flex-shrink: 0;
    animation: starburstPulse 4s ease-in-out infinite;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
  }

  .brand-name {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .brand-title {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--color-warm-gray);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ---- Navigation ---- */
  .sidebar-nav {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 0 0.75rem;
    gap: 2px;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.7rem 0.85rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--text-secondary);
    font-size: 1.05rem;
    font-weight: 500;
    transition: all var(--transition-fast);
    position: relative;
  }

  .nav-link:hover {
    background: rgba(42, 157, 143, 0.06);
    color: var(--text-primary);
  }

  .nav-link:hover .nav-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .nav-link.active {
    background: rgba(42, 157, 143, 0.1);
    color: var(--accent-primary);
    font-weight: 600;
  }

  .nav-link--featured {
    background: rgba(231, 111, 81, 0.08); /* Light Coral background */
    color: var(--accent-secondary);
    border: 1px solid rgba(231, 111, 81, 0.15);
    margin-top: 4px;
    margin-bottom: 4px;
  }

